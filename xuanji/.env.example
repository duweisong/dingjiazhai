# AlphaCouncil2-AI 本地运行环境变量示例
# 复制为 .env 后按需填写；真实 .env 不应提交到仓库。

# 本地 Node 控制面 token；配置后，前端需设置同值的 VITE_ALPHACOUNCIL_API_TOKEN。
ALPHACOUNCIL_API_TOKEN=change_me
VITE_ALPHACOUNCIL_API_TOKEN=change_me

# LLM Provider API Key（按需启用）
GLM_API_KEY=your_glm_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# 可选：覆盖默认 GLM OpenAI-compatible endpoint/model
# GLM_BASE_URL=http://127.0.0.1:3003/v1/chat/completions
# GLM_MODEL=glm-5.2

# 可选：缓存后端，默认 sqlite；可选 redis/memory
# QUANT_CACHE=sqlite
